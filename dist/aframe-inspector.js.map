#aframeInspector .modal button:focus {
  outline: none;
}
#aframeInspector .modal button:hover,
#aframeInspector .modal button.hover {
  background-color: var(--color-primary-hover);
}
#aframeInspector .modal button:active,
#aframeInspector .modal button.active {
  background-color: var(--color-primary-hover);
}
#aframeInspector .modal button:disabled {
  background-color: #666;
  color: #fff;
  cursor: default;
}
#aframeInspector .newimage {
  background-color: var(--color-base-100);
  color: var(--color-base-content);
  display: flex;
  font-size: 13px;
  justify-content: space-between;
  margin-top: 10px;
  overflow: auto;
  padding: 10px;
}
#aframeInspector .newimage input {
  color: var(--color-primary);
  padding: 3px 5px;
}
#aframeInspector .texture canvas + input {
  margin-left: 5px;
}
#aframeInspector .texture svg {
  padding-right: 5px;
}
#aframeInspector .uploader-normal-button .hidden {
  display: none;
}
#aframeInspector .assets.search {
  margin-top: 10px;
  position: relative;
  width: 200px;
}
#aframeInspector .assets.search input {
  box-sizing: border-box;
  padding-right: 20px;
  width: 100%;
}
#aframeInspector .assets.search svg {
  position: absolute;
  right: 5px;
  top: 5px;
}
#aframeInspector .new_asset_options {
  margin: 10px;
}
#aframeInspector .new_asset_options > ul {
  margin-left: 10px;
  padding: 5px;
}
#aframeInspector .new_asset_options > ul > li {
  padding: 10px 0;
}
#aframeInspector .new_asset_options .imageUrl {
  margin-left: 5px;
  width: 350px;
}
#aframeInspector .texture canvas {
  border: 1px solid var(--color-base-100);
  cursor: pointer;
}
#aframeInspector svg:not(:root).svg-inline--fa,
#aframeInspector svg:not(:host).svg-inline--fa {
  box-sizing: content-box;
  overflow: visible;
}
#aframeInspector .svg-inline--fa {
  display: inline-block;
  height: 1em;
  overflow: visible;
  vertical-align: -0.125em;
}
#aframeInspector #viewportBar {
  align-items: center;
  background-color: var(--color-base-200);
  color: var(--color-base-content);
  display: flex;
  flex-grow: 2;
  font-size: 15px;
  height: 32px;
  justify-content: space-between;
  padding: 0 5px;
}
#aframeInspector .toolbarButtons {
  align-items: center;
  display: flex;
  gap: 6px;
}
#aframeInspector .toolbarButtons a.button svg {
  padding: 8px;
}
#aframeInspector .toolbarButtons a.button:not(.active) svg:hover {
  background-color: var(--color-base-lighter);
}
#aframeInspector .toolbarButtons .active svg {
  background-color: var(--color-primary);
  color: var(--color-primary-content);
}
#aframeInspector .toolbarButtons .active:hover svg {
  color: var(--color-primary-content) !important;
}
#aframeInspector .local-transform {
  align-items: center;
  display: flex;
  gap: 5px;
  padding: 0 10px;
}
#aframeInspector .local-transform label {
  color: var(--color-base-content);
}
#aframeInspector #cameraSelect {
  cursor: pointer;
  width: 120px;
}
#aframeInspector #cameraSelect .select__dropdown-indicator {
  padding-left: 3px;
  padding-right: 3px;
}
#aframeInspector #cameraToolbar {
  align-items: center;
  display: flex;
}
#aframeInspector #cameraToolbar .select__control {
  background: none;
}
#aframeInspector #cameraToolbar .select__single-value {
  color: var(--color-base-content);
}
#aframeInspector #cameraToolbar .select__single-value:hover {
  color: var(--color-primary);
}
#aframeInspector #viewportHud {
  display: none;
}
@media (min-width: 1025px) {
  #aframeInspector #viewportHud {
    display: block;
  }
}
#aframeInspector svg:not(:root).svg-inline--fa,
#aframeInspector svg:not(:host).svg-inline--fa {
  box-sizing: content-box;
  overflow: visible;
}
#aframeInspector .svg-inline--fa {
  display: inline-block;
  height: 1em;
  overflow: visible;
  vertical-align: -0.125em;
}
#aframeInspector .select-widget {
  display: inline-block;
  width: 142px;
}
#aframeInspector .select__control,
#aframeInspector code,
#aframeInspector pre,
#aframeInspector input,
#aframeInspector textarea,
#aframeInspector select {
  font-size: 13px;
}
#aframeInspector code,
#aframeInspector pre,
#aframeInspector textarea {
  font-family: var(--font-monospace);
}
#aframeInspector hr {
  border: 0;
  border-top: 1px solid var(--color-base-content);
}
#aframeInspector a {
  cursor: pointer;
}
#aframeInspector button {
  position: relative;
}
#aframeInspector textarea {
  overflow-wrap: normal;
  -moz-tab-size: 4;
    -o-tab-size: 4;
       tab-size: 4;
  white-space: pre;
}
#aframeInspector textarea,
#aframeInspector input {
  outline: none /* osx */;
}
#aframeInspector .gltfIcon svg {
  box-sizing: content-box;
  display: inline;
  height: 20px;
  position: relative;
  top: 4px;
  vertical-align: baseline;
  width: 30px;
}
#aframeInspector #scenegraph,
#aframeInspector #rightPanel {
  z-index: 9998;
}
#aframeInspector #sidebar,
#aframeInspector #scenegraph,
#aframeInspector .panel {
  cursor: default;
  -webkit-user-select: none;
     -moz-user-select: none;
          user-select: none;
}
#aframeInspector .toggle-edit {
  background-color: var(--color-secondary);
  box-sizing: content-box;
  color: var(--color-secondary-content);
  font-size: 13px;
  left: 3px;
  line-height: 16px;
  margin: 0;
  padding: 6px 10px;
  position: fixed;
  text-align: center;
  text-decoration: none;
  top: 3px;
  width: 100px;
  z-index: 999999999;
}
#aframeInspector .toggle-edit:hover {
  background-color: var(--color-secondary-hover);
}
#aframeInspector .try-editor-btn {
  background-color: var(--color-secondary);
  box-sizing: content-box;
  color: var(--color-secondary-content);
  display: flex;
  font-size: 16px;
  gap: 5px;
  justify-content: center;
  line-height: 24px;
  margin: 0;
  padding: 6px 10px;
  text-align: center;
  text-decoration: none;
  width: 200px;
}
#aframeInspector .try-editor-btn:hover {
  background-color: var(--color-secondary-hover);
  color: var(--color-secondary-content);
}
#aframeInspector .sponsor-btn {
  background-color: var(--color-neutral);
  box-sizing: content-box;
  color: var(--color-neutral-content);
  display: flex;
  font-size: 13px;
  gap: 5px;
  justify-content: center;
  left: 127px;
  line-height: 16px;
  margin: 0;
  padding: 6px 10px;
  position: fixed;
  text-align: center;
  text-decoration: none;
  top: 3px;
  width: 80px;
  z-index: 999999999;
}
#aframeInspector .sponsor-btn svg {
  color: #db61a2;
  fill: currentColor;
}
#aframeInspector .sponsor-btn:hover {
  background-color: var(--color-neutral-hover);
  color: var(--color-neutral-content);
}
#aframeInspector input {
  background-color: transparent;
  border: 1px solid var(--color-base-200);
  color: var(--color-base-content);
}
#aframeInspector input,
#aframeInspector .texture canvas {
  transition: 0.1s background-color ease-in-out, 0.1s border-color ease-in-out, 0.1s color ease-in-out;
}
#aframeInspector input[type="text"],
#aframeInspector input[type="number"],
#aframeInspector input.string,
#aframeInspector input.number {
  border-radius: 0;
  min-height: 14px;
  outline: none;
}
#aframeInspector input[type="checkbox"] {
  -webkit-appearance: none;
     -moz-appearance: none;
          appearance: none;
  background: var(--color-base-300);
  border: 1px solid var(--color-base-300);
  border-radius: 0;
  cursor: pointer;
  height: 18px;
  margin: 0;
  position: relative;
  width: 18px;
}
#aframeInspector input[type="checkbox"]:checked {
  background: var(--color-primary);
  border: 1px solid var(--color-base-300);
}
#aframeInspector input[type="checkbox"]:checked::after {
  border: solid #fff;
  border-width: 0 2px 2px 0;
  content: '';
  height: 9px;
  left: 5px;
  position: absolute;
  top: 1px;
  transform: rotate(45deg);
  width: 4px;
}
#aframeInspector input[type="checkbox"]:focus {
  box-shadow: none;
}
#aframeInspector input.number {
  background-color: transparent !important;
  border: 0;
  color: var(--color-primary) !important;
  cursor: col-resize;
  font-size: 13px;
  padding: 2px;
}
#aframeInspector input.string:focus,
#aframeInspector input.number:focus {
  border: 1px solid var(--color-primary);
}
#aframeInspector input.error {
  border: 1px solid var(--color-error);
}
#aframeInspector #sidebar {
  background: var(--color-base-200);
  width: 331px;
}
#aframeInspector input,
#aframeInspector textarea,
#aframeInspector select {
  background: var(--color-base-300);
  border: 1px solid transparent;
  color: var(--color-base-content);
}
#aframeInspector select {
  background: var(--color-base-lighter);
}
#aframeInspector input[type="color"] {
  background-color: var(--color-base-100);
  border: 1px solid var(--color-base-300);
  cursor: pointer;
  height: 26px;
  padding: 0;
  width: 50px;
}
#aframeInspector input[type="color"]::-webkit-color-swatch {
  border: 0 /* To remove the gray border. */;
}
#aframeInspector input[type="color"]::-webkit-color-swatch-wrapper {
  border-radius: 0 /* So it appears as rectangle instead of an ovale in Safari */;
  padding: 0 /* To remove the inner padding. */;
}
#aframeInspector input[type="color"]::-moz-color-swatch {
  border: 0;
}
#aframeInspector input[type="color"]::-moz-focus-inner {
  border: 0 /* To remove the inner border (specific to Firefox). */;
  padding: 0;
}
#aframeInspector .copy-tooltip {
  background-color: var(--color-base-200);
  border: 1px solid var(--color-base-content);
  color: var(--color-base-content);
  padding: 10px;
  white-space: nowrap;
  z-index: 999999;
}
#aframeInspector .hidden {
  visibility: hidden;
}
#aframeInspector a.button {
  color: var(--color-base-content);
  font-size: 16px;
  line-height: 1em;
  text-decoration: none;
}
#aframeInspector a.button:hover {
  color: var(--color-primary);
}
#aframeInspector .hide {
  display: none;
}
#aframeInspector .a-canvas.state-dragging {
  cursor: grabbing;
}
#aframeInspector #rightPanel {
  align-items: stretch;
  display: flex;
  justify-content: flex-end;
}
#aframeInspector #inspectorContainer {
  display: flex;
  height: 100%;
  justify-content: space-between;
  left: 0;
  pointer-events: none;
  position: fixed;
  top: 0;
  width: 100%;
  z-index: 999999;
}
#aframeInspector #scenegraph,
#aframeInspector #viewportBar,
#aframeInspector #rightPanel {
  pointer-events: all;
}
#aframeInspector .aframe-inspector-opened a-scene .a-canvas {
  background-color: #191919;
  z-index: 9998;
}
#aframeInspector .toggle-sidebar {
  align-items: center;
  display: flex;
  height: 100%;
  position: absolute;
  z-index: 9998;
}
#aframeInspector .toggle-sidebar a {
  background-color: var(--color-base-200);
  color: var(--color-base-content);
  padding: 5px;
  z-index: 9998;
}
#aframeInspector .toggle-sidebar a.hover {
  background-color: var(--color-primary);
  color: var(--color-primary-content);
}
#aframeInspector .toggle-sidebar.left {
  left: 0;
  top: 0;
}
#aframeInspector .toggle-sidebar.right {
  right: 0;
  top: 0;
}
@keyframes animateopacity {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
